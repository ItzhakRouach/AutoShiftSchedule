NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron job auth — set to a strong random secret; Vercel sends it automatically
CRON_SECRET=

# Evolution API (self-hosted WhatsApp gateway) — used to auto-send the schedule
# to the work group and a personal message to each worker. Leave blank to skip
# sending (the schedule still publishes). The instance must be a connected
# WhatsApp number added to each work group.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
